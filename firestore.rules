rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isMaster() {
      return isAuthenticated() && (
        (request.auth.token.email == "joliveira2752@gmail.com" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'master')
      );
    }

    function isBranchAdmin(branchId) {
      let userData = getUserData();
      return isAuthenticated() && userData.role == 'admin' && userData.branchId == branchId;
    }

    function isBranchUser(branchId) {
      let userData = getUserData();
      return isAuthenticated() && (userData.role == 'user' || userData.role == 'admin') && userData.branchId == branchId;
    }

    // Branches
    match /branches/{branchId} {
      allow read: if isAuthenticated();
      allow write: if isMaster();
    }

    // Users
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isMaster());
      allow write: if isMaster() || (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'branchId']));
      allow create: if isMaster() || (request.auth.uid == userId && request.resource.data.role == 'user');
    }

    // Freights
    match /freights/{freightId} {
      allow read: if isMaster() || isBranchUser(resource.data.branchId);
      allow create: if isMaster() || isBranchAdmin(request.resource.data.branchId);
      allow update: if isMaster() || isBranchAdmin(resource.data.branchId);
      allow delete: if isMaster() || isBranchAdmin(resource.data.branchId);
    }

    // Loadings
    match /loadings/{loadingId} {
      allow read: if isMaster() || isBranchUser(resource.data.branchId);
      allow create: if isMaster() || isBranchAdmin(request.resource.data.branchId);
      allow update: if isMaster() || isBranchAdmin(resource.data.branchId);
      allow delete: if isMaster() || isBranchAdmin(resource.data.branchId);
    }

    // Employees
    match /employees/{employeeId} {
      allow read: if isMaster() || isBranchUser(resource.data.branchId);
      allow create: if isMaster() || isBranchAdmin(request.resource.data.branchId);
      allow update: if isMaster() || isBranchAdmin(resource.data.branchId);
      allow delete: if isMaster() || isBranchAdmin(resource.data.branchId);
    }
  }
}
